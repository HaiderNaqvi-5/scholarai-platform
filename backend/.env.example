APP_NAME=ScholarAI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://scholarai:password@localhost:5432/scholarai
SQL_ECHO=false

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

SECRET_KEY=change-me-in-production-min-32-chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

MVP_PRIMARY_COUNTRY=CA
MVP_SECONDARY_COUNTRY=US
MVP_FULBRIGHT_KEYWORD=fulbright
AUTO_SEED_DEMO_DATA=true  # dev only — leave UNSET in production; production assertion rejects True.
DEMO_STUDENT_EMAIL=student@example.com
DEMO_STUDENT_PASSWORD=strongpass1
DEMO_STUDENT_FULL_NAME=ScholarAI Demo Student
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=strongpass1
DEMO_ADMIN_FULL_NAME=ScholarAI Demo Admin

CORS_ORIGINS=["http://localhost:3000"]

# ── Mailgun (S87 — log-only fallback when unset; see services/notifications/channels.py) ──
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAILGUN_TIMEOUT_SECONDS=10
BRAND_DISPLAY_NAME=AidwiseAI
EMAIL_FROM_LOCALPART=notify

# ── Sentry (gated by SENTRY_DSN; unset = no init, app boots clean) ──
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.10
SENTRY_PROFILES_SAMPLE_RATE=0.10
SENTRY_ENVIRONMENT=development
