# ScholarAI local demo environment
# Copy to .env at the repository root when using Docker Compose.

APP_NAME=ScholarAI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# Docker Compose service names are used here intentionally.
DATABASE_URL=postgresql+asyncpg://scholarai:password@postgres:5432/scholarai
DB_PASSWORD=password

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

SECRET_KEY=change-me-in-production-min-32-chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

MVP_PRIMARY_COUNTRY=CA
MVP_SECONDARY_COUNTRY=US
MVP_FULBRIGHT_KEYWORD=fulbright
AUTO_SEED_DEMO_DATA=true
DEMO_STUDENT_EMAIL=student@example.com
DEMO_STUDENT_PASSWORD=strongpass1
DEMO_STUDENT_FULL_NAME=ScholarAI Demo Student
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=strongpass1
DEMO_ADMIN_FULL_NAME=ScholarAI Demo Admin

# JSON list syntax is required for the backend settings parser.
CORS_ORIGINS=["http://localhost:3000"]

# Exposed to the browser bundle in local demo mode.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
